+def _validate_technology_tree_candidate(candidate: Any) -> list[str]:
+    errors: list[str] = []
+    if not isinstance(candidate, dict):
+        return ["дерево технологий не является словарём"]
+    if len(candidate) != 100:
+        errors.append(f"ожидалось 100 технологий, получено {len(candidate)}")
+    for key, tech in candidate.items():
+        if not isinstance(key, str) or not key.strip():
+            errors.append("найден пустой или нестроковый ID технологии")
+            continue
+        if not isinstance(tech, dict):
+            errors.append(f"{key}: запись не является словарём")
+            continue
+        if not str(tech.get("name", "")).strip():
+            errors.append(f"{key}: отсутствует название")
+        for prereq in safe_list(tech.get("prereq")):
+            if prereq not in candidate:
+                errors.append(f"{key}: неизвестная предпосылка {prereq!r}")
+    return errors
+
+
+def _load_technology_json_file(path: str) -> dict | None:
+    try:
+        with open(path, "r", encoding="utf-8") as handle:
+            data = json.load(handle)
+    except (OSError, json.JSONDecodeError):
+        return None
+    return data if isinstance(data, dict) else None
+
+
+def _load_technology_lua_file(path: str) -> dict | None:
+    try:
+        from lupa import LuaRuntime
+    except Exception:
+        return None
+    try:
+        with open(path, "r", encoding="utf-8") as handle:
+            lua = LuaRuntime(unpack_returned_tuples=True)
+            data = _lua_table_to_python(lua.execute(handle.read()))
+    except Exception as exc:
+        debug_log("Technology Lua load error %s: %s", path, exc, level=logging.WARNING)
+        return None
+    return data if isinstance(data, dict) else None
+
+
+def load_technology_content(strict: bool = False) -> str:
+    """Финально загружает одно дерево технологий и больше не даёт его затирать.
+
+    Приоритет источников:
+      1. technologies.lua рядом с игрой;
+      2. technology_tree_100.json рядом с игрой;
+      3. встроенный проверенный roma_technology_overhaul.py.
+
+    Файлы в mods/core и data используются только как резерв совместимости.
+    """
+    global TECH_TREE, SCIENCE_TECH_META, TECHNOLOGY_CONTENT_SOURCE
+
+    candidates: list[tuple[str, dict | None]] = []
+    for candidate_path in TECHNOLOGY_LUA_CANDIDATES:
+        if os.path.isfile(candidate_path):
+            candidates.append((candidate_path, _load_technology_lua_file(candidate_path)))
+    for candidate_path in TECHNOLOGY_JSON_CANDIDATES:
+        if os.path.isfile(candidate_path):
+            candidates.append((candidate_path, _load_technology_json_file(candidate_path)))
+
+    # Проверенный Python-модуль всегда остаётся последней страховкой.
+    candidates.append(("roma_technology_overhaul.py", _technology_copy.deepcopy(TECHNOLOGY_OVERHAUL.TECH_TREE)))
+
+    rejected: list[str] = []
+    for source, candidate in candidates:
+        if candidate is None:
+            rejected.append(f"{source}: не удалось прочитать")
+            continue
+        errors = _validate_technology_tree_candidate(candidate)
+        if errors:
+            rejected.append(f"{source}: {'; '.join(errors[:4])}")
+            continue
+        TECH_TREE = _technology_copy.deepcopy(candidate)
+        SCIENCE_TECH_META = {
+            key: {
+                "era": safe_int(tech.get("era"), 1, 1, 5),
+                "branch": str(tech.get("branch", TECH_CATEGORY_LABELS.get(tech.get("category"), "Общее"))),
+            }
+            for key, tech in TECH_TREE.items()
+        }
+        TECHNOLOGY_CONTENT_SOURCE = source
+        debug_log("Technology tree loaded from %s (%s nodes)", source, len(TECH_TREE), level=logging.INFO)
+        return source
+
+    message = "Не удалось загрузить корректное дерево технологий: " + " | ".join(rejected)
+    if strict:
+        raise RuntimeError(message)
+    debug_log(message, level=logging.ERROR)
+    return ""
+
+
+def validate_technology_quote_sync(strict: bool = False) -> list[str]:
+    errors: list[str] = []
+    missing = sorted(set(TECH_TREE) - set(TECH_QUOTES))
+    extra = sorted(set(TECH_QUOTES) - set(TECH_TREE))
+    if missing:
+        errors.append(f"нет цитат для: {missing}")
+    if extra:
+        errors.append(f"лишние цитаты: {extra}")
+    if strict and errors:
+        raise RuntimeError("TECH_QUOTES mismatch: " + "; ".join(errors))
+    return errors
+
